rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admins collection ─────────────────────────────────
    // Only currently active admins can read or write admin docs.
    // You can manage this from the Firebase Console.
    match /admins/{email} {
      // Any authenticated user can read (to check their own admin status)
      allow read: if request.auth != null;
      // Only existing active admins can add/remove/edit admin records
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.active == true;
    }

    // ── Bookings ──────────────────────────────────────────
    // Any logged-in user can create a booking
    // Any logged-in user can read bookings (admin checks happen in app logic)
    // Only admins can update/delete
    match /bookings/{bookingId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update, delete: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.active == true;
    }

    // ── Everything else ───────────────────────────────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}